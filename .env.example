DATABASE_URL=postgresql+psycopg://wr_wh_leads:CHANGE_ME_DB_PASSWORD@127.0.0.1:5432/wr_wh_leads_prod

# Webhook
WEBHOOK_SECRET=

# Mail
# Почта-отправитель (должна быть доверенной в Яндексе).
YANDEX_EMAIL=your_email@yandex.ru
# Пароль приложения Яндекс 360/Почты (не обычный пароль от входа).
YANDEX_APP_PASSWORD=your_app_password
# Куда отправлять лиды.
TO_EMAIL=npp-rekord@yandex.ru
SMTP_SERVER=smtp.yandex.com
SMTP_PORT=465
# Таймаут SMTP-подключения в секундах.
SMTP_TIMEOUT_SECONDS=20
# Пауза между письмами, чтобы не спамить SMTP.
EMAIL_SEND_DELAY_SECONDS=5
# Максимум попыток отправки одного лида.
# 5 = до 5 попыток при ошибках сети/SMTP.
# 0 = отправка писем полностью отключена (лиды все равно пишутся в БД).
EMAIL_MAX_ATTEMPTS=5
# Пауза между циклами проверки новых лидов на отправку.
EMAIL_POLL_INTERVAL_SECONDS=2
# Подпись часового пояса в тексте письма.
EMAIL_TIMEZONE_LABEL=UTC +3
# Город для поля "Город" в письме (берется всегда из env, не из payload).
CITY_LEADS=Moscow

# Google Sheets credentials
GOOGLE_CREDENTIALS_FILE=credentials/sheets-data-bot-b8f4cc6634fc.json

#ТЕСТ Выгрузка по конкурентам
GOOGLE_SHEET_ID=
GOOGLE_SHEET_NAME=
# Путь к логам скрипта выгрузки лидов в Google Sheets.
EXPORT_LEADS_LOG_PATH=logs/export_leads_to_sheet.log